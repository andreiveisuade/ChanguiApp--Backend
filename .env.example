# ======================================
# ChanguiApp Backend — Variables de Entorno
# ======================================
# Copiar este archivo a .env y completar con los valores reales.
# NUNCA commitear el archivo .env (está en .gitignore).
# Las credenciales reales se comparten por el grupo de WhatsApp.

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Supabase ---
# Obtener de: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Mercado Pago (sandbox) ---
# Obtener de: https://www.mercadopago.com.ar/developers → Credenciales de prueba
MERCADO_PAGO_ACCESS_TOKEN=TEST-...

# --- Precios Claros (API pública, sin key) ---
PRECIOS_CLAROS_BASE_URL=https://d3e6htiiul5ek9.cloudfront.net/prod
