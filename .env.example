# URL del proyecto Supabase
SUPABASE_URL=

# Clave pública (anon). Usada para validar tokens JWT del cliente móvil.
SUPABASE_ANON_KEY=

# Clave de servicio (service_role). SOLO backend y scripts admin. NUNCA exponer al cliente móvil.
# Bypassa Row Level Security. Rotar si se compromete.
SUPABASE_SERVICE_ROLE_KEY=

# Token secreto para proteger endpoints admin (ej: /api/admin/sync-precios-claros).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Guardar en Render Environment Variables y en el gestor de secrets del equipo.
ADMIN_TOKEN=

# Access token de Mercado Pago (modo sandbox para desarrollo)
MP_ACCESS_TOKEN=

# URL base de la API de Precios Claros (SEPA)
PRECIOS_CLAROS_URL=

# Token de administrador
ADMIN_TOKEN=

# ID del store de MVP
MVP_STORE_PRECIOS_CLAROS_ID=

# Puerto del servidor Express (default 3000 en desarrollo)
PORT=3000
