{
  "name": "changuiapp--backend",
  "version": "1.0.0",
  "description": "API REST en Node.js + TypeScript + Express para ChanguiApp — Carrito de Compras Inteligente. Integra la API de Precios Claros (SEPA) del gobierno argentino para obtener precios reales de productos de supermercado, con autenticacion via Supabase Auth y persistencia en PostgreSQL.",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreiveisuade/ChanguiApp--Backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/andreiveisuade/ChanguiApp--Backend/issues"
  },
  "homepage": "https://github.com/andreiveisuade/ChanguiApp--Backend#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mercadopago": "^1.5.17",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  }
}
